{
  "name": "hybrid-e2e-framework",
  "version": "1.0.0",
  "description": "Production-grade E2E test automation framework — Playwright + TypeScript + BDD + API + Performance + AI",
  "author": "Usahan",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=chromium tests/ui/",
    "test:api": "playwright test tests/api/",
    "test:visual": "playwright test tests/ui/visual.spec.ts --update-snapshots",
    "test:a11y": "playwright test tests/ui/accessibility.spec.ts",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:critical": "playwright test --grep @critical",
    "test:headed": "playwright test --headed --project=chromium",
    "test:demo": "tsx scripts/record-demo.ts",
    "test:debug": "PWDEBUG=1 playwright test --project=chromium",
    "test:shard": "playwright test --shard=$SHARD",
    "test:bdd": "cucumber-js --config cucumber.cjs",
    "test:perf:load": "k6 run k6/load-test.js",
    "test:perf:stress": "k6 run k6/stress-test.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,yml,md}\"",
    "typecheck": "tsc --noEmit",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:serve": "allure serve allure-results",
    "prepare": "husky",
    "ci:quality": "npm run lint && npm run typecheck && npm run format:check"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@cucumber/cucumber": "^11.2.0",
    "@faker-js/faker": "^9.4.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "allure-commandline": "^2.32.0",
    "allure-playwright": "^3.2.0",
    "dotenv": "^16.4.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^2.1.0",
    "husky": "^9.1.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
