# =============================================================================
# Environment Configuration — copy to .env and fill in values
# =============================================================================
# Usage: cp .env.example .env

# --- Target Environment ---
# Options: dev | staging | prod
TEST_ENV=dev

# --- SauceDemo (UI Tests) ---
BASE_URL=https://www.saucedemo.com
# Standard user — unlocked, happy-path flows
UI_USERNAME=standard_user
UI_PASSWORD=secret_sauce

# --- Swagger Petstore (API Tests) ---
API_BASE_URL=https://petstore.swagger.io/v2
API_KEY=special-key

# --- Claude AI (Test Generation Script) ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Browser Config ---
# Override the default headed/headless mode
# HEADLESS=true

# --- Allure ---
# ALLURE_RESULTS_DIR=allure-results
